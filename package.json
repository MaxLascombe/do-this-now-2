{
  "name": "do-this-now-2-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "mobile:start": "pnpm --filter mobile start",
    "mobile:ios": "pnpm --filter mobile ios",
    "test": "pnpm --filter @dtn/shared test && pnpm --filter web test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "@tanstack/react-query": "5.100.10"
    }
  }
}
