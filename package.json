{
  "name": "do-this-now-2-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "mobile:start": "pnpm --filter mobile start",
    "mobile:ios": "pnpm --filter mobile ios",
    "dev": "concurrently -n web,mobile -c blue,green \"pnpm web:dev\" \"pnpm mobile:start\"",
    "typecheck": "pnpm --filter @dtn/shared exec tsc --noEmit && pnpm --filter web exec tsc --noEmit && pnpm --filter mobile exec tsc --noEmit",
    "test": "pnpm --filter @dtn/shared test && pnpm --filter web test",
    "db:studio": "pnpm --filter web exec drizzle-kit studio",
    "db:generate": "pnpm --filter web exec drizzle-kit generate",
    "db:check": "pnpm --filter web exec drizzle-kit check"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "@tanstack/react-query": "5.100.10"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
