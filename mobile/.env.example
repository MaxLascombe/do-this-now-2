# URL of the deployed web app — mobile hits its /api routes over the network.
# In dev, point at your laptop's IP if testing on a physical phone, or
# http://localhost:3000 if running the web app locally on the same host.
EXPO_PUBLIC_API_URL=https://dothisnow.maxlascombe.com

# Clerk publishable key — must be the same instance as the web app so
# Bearer tokens are valid on both sides.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
